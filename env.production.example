# Production Environment Variables for Vercel
# Copy these values to your Vercel environment variables

# Database Configuration
MONGODB_URI=mongodb+srv://tiedlowai:rw31X6IU4H4ZbTPn@tielo.fmnn3sm.mongodb.net/hr?retryWrites=true&w=majority&appName=tielo
MONGODB_DB_NAME=hr

# Clerk Authentication (PRODUCTION KEYS - NOT TEST KEYS)
# You need to get these from your Clerk dashboard
CLERK_SECRET_KEY=sk_live_your_production_secret_key_here
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_your_production_publishable_key_here

# Clerk Configuration URLs (Updated for subdomain support)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Clerk Webhook Secret
CLERK_WEBHOOK_SECRET=whsec_your_production_webhook_secret_here

# Environment
NODE_ENV=production

# OpenAI API (if using AI features)
OPENAI_API_KEY=sk-proj-your_openai_api_key_here

# AWS S3 Configuration (if using file uploads)
AWS_S3_BUCKET_NAME=your_production_bucket_name
AWS_S3_REGION=us-east-2
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# App URLs (Updated for simplified subdomain support)
NEXT_PUBLIC_APP_URL=https://portal.tielo.io
NEXT_PUBLIC_BASE_URL=https://portal.tielo.io

# Voice Commands Configuration
NEXT_PUBLIC_VOICE_COMMANDS_ENABLED=true

# SendGrid Email (production)
SENDGRID_API_KEY=your_production_sendgrid_api_key
SENDGRID_FROM_EMAIL=no-reply@yourdomain.com

# Logging Configuration
# Set to 'true' to disable console logs in production (default: logs enabled)
# DISABLE_PRODUCTION_LOGS=false
